<div class="min-h-screen bg-[#0a0c12] bg-grid pt-24 px-4 pb-16">
  <div class="max-w-xl mx-auto">
    <a href="/" class="text-sm text-slate-400 hover:text-white transition-colors mb-6 inline-block">← Back to Dashboard</a>
    
    <div class="bg-surface border border-border rounded-2xl p-8 shadow-2xl glow-violet">
      <h2 class="text-2xl font-bold text-white mb-6">Your Profile</h2>

      <form action="/profile/update" method="POST" enctype="multipart/form-data">
        <div class="flex items-center gap-6 mb-8">
          <div class="relative group">
            <% if (user.profilePic) { %>
              <img src="<%= user.profilePic %>" class="w-20 h-20 rounded-full object-cover border-2 border-violet-500/50" />
            <% } else { %>
              <div class="w-20 h-20 rounded-full bg-slate-800 flex items-center justify-center text-3xl select-none">👤</div>
            <% } %>
            <label class="absolute inset-0 bg-black/60 rounded-full flex flex-col items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer">
              <span class="text-[10px] text-white">Upload</span>
              <input type="file" name="profilePic" class="hidden" accept="image/*" />
            </label>
          </div>
          <div>
            <h3 class="text-white font-bold"><%= user.name || 'Unnamed User' %></h3>
            <p class="text-slate-400 text-sm">@<%= user.username || user.email.split('@')[0] %></p>
          </div>
        </div>

        <div class="space-y-4 mb-8">
          <div>
            <label class="block text-xs font-semibold text-slate-400 uppercase tracking-widest mb-2">Name</label>
            <input type="text" name="name" value="<%= user.name || '' %>" placeholder="Your Name" class="w-full bg-[#0a0c12] border border-border rounded-xl px-4 py-2.5 text-white placeholder-slate-700 focus:border-violet-500 transition-colors text-sm" />
          </div>
          
          <div>
            <label class="block text-xs font-semibold text-slate-400 uppercase tracking-widest mb-2">Username</label>
            <input type="text" name="username" value="<%= user.username || '' %>" placeholder="username" class="w-full bg-[#0a0c12] border border-border rounded-xl px-4 py-2.5 text-white placeholder-slate-700 focus:border-violet-500 transition-colors text-sm" />
          </div>

          <div>
            <label class="block text-xs font-semibold text-slate-400 uppercase tracking-widest mb-2">Email</label>
            <input type="email" name="email" value="<%= user.email || '' %>" required class="w-full bg-[#0a0c12] border border-border rounded-xl px-4 py-2.5 text-white placeholder-slate-700 focus:border-violet-500 transition-colors text-sm" />
          </div>

          <div>
            <label class="block text-xs font-semibold text-slate-400 uppercase tracking-widest mb-2">New Password (leave blank to keep current)</label>
            <input type="password" name="password" placeholder="••••••••" class="w-full bg-[#0a0c12] border border-border rounded-xl px-4 py-2.5 text-white placeholder-slate-700 focus:border-violet-500 transition-colors text-sm" />
          </div>
        </div>

        <div class="flex flex-col gap-4">
          <button type="submit" class="w-full py-3 rounded-xl btn-primary text-sm font-semibold">Save Changes</button>
        </div>
      </form>

      <div class="mt-8 border-t border-border pt-8">
        <h3 class="text-white font-bold mb-4">Linked Accounts</h3>
        <div class="flex items-center justify-between p-4 rounded-xl border border-border bg-[#0a0c12]">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            <span class="text-sm font-semibold text-white">Google Drive</span>
          </div>
          <% if (user.googleId) { %>
            <form action="/profile/unlink-google" method="POST">
              <button type="submit" class="px-3 py-1.5 rounded-lg border border-red-500/30 text-xs text-red-400 hover:bg-red-500/10 transition-colors">Unlink</button>
            </form>
          <% } else { %>
            <a href="/auth/google" class="px-3 py-1.5 rounded-lg border border-border text-xs text-slate-300 hover:text-white transition-colors">Link Account</a>
          <% } %>
        </div>
      </div>

    </div>
  </div>
</div>
<script>
  window.onload = () => {
    const params = new URLSearchParams(window.location.search);
    if(params.has('success')) showToast('Profile updated', 'success');
    if(params.has('error')) showToast(params.get('error'), 'error');
  };
</script>
