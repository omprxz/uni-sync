<div class="p-6 md:p-12 max-w-2xl mx-auto">
  <div class="flex items-center gap-4 mb-8">
    <div class="w-12 h-12 rounded-xl bg-violet-500/10 flex items-center justify-center text-violet-400 border border-violet-500/20">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
    </div>
    <div>
      <h2 class="text-3xl font-bold text-white tracking-tight">Profile Settings</h2>
      <p class="text-slate-400 text-sm mt-1">Manage your account details and connected services.</p>
    </div>
  </div>

  <div class="bg-surface border border-border rounded-3xl p-6 md:p-10 shadow-2xl relative overflow-hidden">
    <!-- Decorative background glow -->
    <div class="absolute -top-40 -right-40 w-80 h-80 bg-violet-600/10 rounded-full blur-3xl pointer-events-none"></div>

    <form action="/profile/update" method="POST" enctype="multipart/form-data" class="relative z-10">
      <div class="flex flex-col md:flex-row items-center gap-8 mb-10 pb-10 border-b border-border/50">
        <div class="relative group cursor-pointer">
          <% if (user.profilePic) { %>
            <img src="<%= user.profilePic %>" class="w-28 h-28 rounded-full object-cover border-4 border-surface shadow-xl ring-2 ring-violet-500/50 transition-transform group-hover:scale-105" />
          <% } else { %>
            <div class="w-28 h-28 rounded-full bg-slate-800 flex items-center justify-center text-4xl select-none border-4 border-surface shadow-xl ring-2 ring-violet-500/50 transition-transform group-hover:scale-105">👤</div>
          <% } %>
          <div class="absolute inset-0 bg-black/60 rounded-full flex flex-col items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
            <svg class="w-6 h-6 text-white mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="text-[10px] text-white font-semibold uppercase tracking-wider">Upload</span>
          </div>
          <input type="file" name="profilePic" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" accept="image/*" />
        </div>
        <div class="text-center md:text-left">
          <h3 class="text-xl font-bold text-white"><%= user.name || 'Unnamed User' %></h3>
          <p class="text-violet-400 text-sm font-medium mt-1">@<%= user.username || user.email.split('@')[0] %></p>
        </div>
      </div>

      <div class="space-y-6 mb-10">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Full Name</label>
            <input type="text" name="name" value="<%= user.name || '' %>" placeholder="John Doe" class="w-full bg-[#0a0c12]/50 border border-border rounded-xl px-4 py-3 text-white placeholder-slate-700 focus:border-violet-500 focus:bg-[#0a0c12] hover:border-slate-600 transition-all text-sm shadow-inner" />
          </div>
          <div>
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Username</label>
            <input type="text" name="username" value="<%= user.username || '' %>" placeholder="username" class="w-full bg-[#0a0c12]/50 border border-border rounded-xl px-4 py-3 text-white placeholder-slate-700 focus:border-violet-500 focus:bg-[#0a0c12] hover:border-slate-600 transition-all text-sm shadow-inner" />
          </div>
        </div>

        <div>
          <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Email Address</label>
          <input type="email" name="email" value="<%= user.email || '' %>" required class="w-full bg-[#0a0c12]/50 border border-border rounded-xl px-4 py-3 text-white placeholder-slate-700 focus:border-violet-500 focus:bg-[#0a0c12] hover:border-slate-600 transition-all text-sm shadow-inner" />
        </div>

        <div>
          <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">New Password <span class="text-slate-600 font-normal normal-case">(leave blank to keep current)</span></label>
          <input type="password" name="password" placeholder="••••••••" class="w-full bg-[#0a0c12]/50 border border-border rounded-xl px-4 py-3 text-white placeholder-slate-700 focus:border-violet-500 focus:bg-[#0a0c12] hover:border-slate-600 transition-all text-sm shadow-inner" />
        </div>
      </div>

      <div class="flex justify-end pt-6 border-t border-border/50">
        <button type="submit" class="px-8 py-3 rounded-xl btn-primary text-sm font-semibold shadow-lg shadow-violet-500/20 px-8">Save Profile Settings</button>
      </div>
    </form>
  </div>

  <!-- Connected Services -->
  <div class="mt-8">
    <h3 class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-4 px-2">Connected Integrations</h3>
    <div class="bg-surface border border-border rounded-2xl p-5 shadow-lg flex items-center justify-between hover:border-slate-700 transition-colors">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl bg-[#0a0c12] border border-border flex items-center justify-center shrink-0">
          <svg class="w-6 h-6" viewBox="0 0 24 24"><path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        </div>
        <div>
          <span class="text-base font-bold text-white block">Google Drive</span>
          <% if (user.googleId) { %>
            <span class="text-xs text-emerald-400 font-medium flex items-center gap-1 mt-0.5">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 block"></span> Connected
              <% if (user.googleEmail) { %>
                <span class="text-slate-500 ml-1 font-normal">(<%= user.googleEmail %>)</span>
              <% } %>
            </span>
          <% } else { %>
            <span class="text-xs text-slate-500 font-medium block mt-0.5">Not connected</span>
          <% } %>
        </div>
      </div>
      <% if (user.googleId) { %>
        <form action="/profile/unlink-google" method="POST">
          <button type="submit" class="px-4 py-2 rounded-xl border border-red-500/20 text-sm font-semibold text-red-500 hover:bg-red-500/10 transition-colors">Disconnect</button>
        </form>
      <% } else { %>
        <a href="/auth/google" class="px-4 py-2 rounded-xl bg-white text-black text-sm font-bold shadow-md hover:bg-slate-200 transition-colors">Link Account</a>
      <% } %>
    </div>
  </div>
</div>

<script>
  window.onload = () => {
    const params = new URLSearchParams(window.location.search);
    if(params.has('success')) {
      if (params.get('success') === 'unlinked') {
        showToast('Google account disconnected', 'info');
      } else {
        showToast('Profile updated successfully', 'success');
      }
      window.history.replaceState({}, document.title, "/profile");
    }
    if(params.has('error')) {
      showToast(params.get('error'), 'error');
      window.history.replaceState({}, document.title, "/profile");
    }
  };
</script>
