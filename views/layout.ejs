<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <script>
    (function() {
      const saved = localStorage.getItem('droproom-theme');
      if (saved === 'light') {
        document.documentElement.classList.remove('dark');
        document.documentElement.classList.add('light');
      }
    })();
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <meta name="description" content="DropRoom — real-time text sharing. Drop snippets, links, code, and notes across devices with a 6-digit room code. No login required." />
  <link rel="manifest" href="/manifest.json" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/logo-icon.png" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: { sans: ['Inter', 'sans-serif'], mono: ['JetBrains Mono', 'monospace'] },
          colors: {
            surface: { DEFAULT: '#12141e', 2: '#1a1d2e', 3: '#1f2235' },
            border: { DEFAULT: '#252840', light: '#2f3350' },
          },
          animation: {
            'fade-in': 'fadeIn 0.3s ease-out',
            'slide-up': 'slideUp 0.35s cubic-bezier(0.16, 1, 0.3, 1)',
            'slide-down': 'slideDown 0.25s ease-out',
            'pulse-soft': 'pulseSoft 2s ease-in-out infinite',
          },
          keyframes: {
            fadeIn: { from: { opacity: '0' }, to: { opacity: '1' } },
            slideUp: { from: { opacity: '0', transform: 'translateY(16px)' }, to: { opacity: '1', transform: 'translateY(0)' } },
            slideDown: { from: { opacity: '0', transform: 'translateY(-8px)' }, to: { opacity: '1', transform: 'translateY(0)' } },
            pulseSoft: { '0%,100%': { opacity: '1' }, '50%': { opacity: '0.5' } },
          }
        }
      }
    }
  </script>

  <!-- Highlight.js -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>

  <!-- Marked.js -->
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

  <!-- QRCode.js -->
  <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>

  <!-- DOMPurify -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/dompurify/3.1.5/purify.min.js"></script>

  <style>
    * { box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: #0a0c12; color: #e2e8f0; }
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #2f3350; border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: #7c3aed; }
    .glass { background: rgba(18,20,30,0.8); backdrop-filter: blur(12px); }
    .glow-violet { box-shadow: 0 0 30px rgba(124,58,237,0.15); }
    .glow-violet-sm { box-shadow: 0 0 12px rgba(124,58,237,0.25); }
    .card-enter { animation: slideUp 0.35s cubic-bezier(0.16, 1, 0.3, 1); }
    .type-text { border-top: 2px solid #7c3aed; }
    .type-link { border-top: 2px solid #3b82f6; }
    .type-code { border-top: 2px solid #10b981; }
    .type-markdown { border-top: 2px solid #f59e0b; }
    pre code.hljs { border-radius: 8px; font-family: 'JetBrains Mono', monospace; font-size: 0.82rem; }
    .markdown-body h1,.markdown-body h2,.markdown-body h3 { color: #f1f5f9; font-weight: 700; }
    .markdown-body h1 { font-size: 1.5rem; margin-bottom: 0.5rem; }
    .markdown-body h2 { font-size: 1.25rem; margin-bottom: 0.4rem; }
    .markdown-body p { color: #94a3b8; margin-bottom: 0.5rem; line-height: 1.6; }
    .markdown-body ul,.markdown-body ol { padding-left: 1.25rem; color: #94a3b8; }
    .markdown-body li { margin-bottom: 0.25rem; }
    .markdown-body code { background: #1f2235; padding: 0.1rem 0.35rem; border-radius: 4px; font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: #a78bfa; }
    .markdown-body blockquote { border-left: 3px solid #7c3aed; padding-left: 0.75rem; color: #64748b; margin: 0.5rem 0; }
    .markdown-body a { color: #818cf8; text-decoration: underline; }
    .markdown-body strong { color: #f1f5f9; }
    .bg-grid { background-image: linear-gradient(rgba(124,58,237,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(124,58,237,0.04) 1px, transparent 1px); background-size: 48px 48px; }
    .hidden { display: none !important; }
    .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border-width: 0; }
    input[type=text]:focus, textarea:focus { outline: none; }
    .btn-primary { background: linear-gradient(135deg, #7c3aed, #4f46e5); color: white; font-weight: 600; transition: all 0.2s; }
    .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 8px 24px rgba(124,58,237,0.35); }
    .btn-primary:active { transform: translateY(0); }
    .toast { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 9999; }
    .pill-active { background: linear-gradient(135deg, #7c3aed, #4f46e5); color: white; }
    .pill-inactive { background: transparent; color: #64748b; }
    .pill-inactive:hover { color: #94a3b8; background: rgba(255,255,255,0.05); }
  
    /* Light Mode Overrides */
    html.light body { background: #f8fafc; color: #0f172a; }
    html.light .bg-\[\#0a0c12\] { background-color: #f8fafc !important; }
    html.light .bg-\[\#0a0c12\]\/90 { background-color: rgba(248, 250, 252, 0.9) !important; }
    html.light .bg-\[\#0a0c12\]\/50 { background-color: rgba(248, 250, 252, 0.5) !important; }
    html.light .bg-surface { background-color: #ffffff !important; }
    html.light .border-border, html.light .border-border\/50, html.light .border-border\/30 { border-color: #e2e8f0 !important; }
    html.light .text-white { color: #0f172a !important; }
    html.light .text-slate-400 { color: #64748b !important; }
    html.light .text-slate-300 { color: #475569 !important; }
    html.light .text-slate-500 { color: #64748b !important; }
    html.light .text-slate-600 { color: #94a3b8 !important; }
    html.light .hover\:text-white:hover { color: #000000 !important; }
    html.light input, html.light textarea, html.light select { background-color: #ffffff !important; color: #0f172a !important; border-color: #cbd5e1 !important; }
    html.light .item-card { border-color: #cbd5e1 !important; background: #ffffff !important; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05) !important; }
    html.light .pill-inactive { color: #64748b !important; }
    html.light .pill-inactive:hover { background: #f1f5f9 !important; color: #0f172a !important; }
    html.light .filter-pill { border: none !important; }
</style>
</head>
<body class=" min-h-screen bg-[#0a0c12]">

  <%- body %>

  <!-- Toast container -->
  <div id="toast-container" class="toast flex flex-col gap-2 pointer-events-none"></div>

  <!-- QR Modal -->
  <div id="qr-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/70 backdrop-blur-sm">
    <div class="bg-surface rounded-2xl border border-border p-6 w-80 text-center shadow-2xl animate-slide-up">
      <div class="flex justify-between items-center mb-4">
        <span class="font-semibold text-white">QR Code</span>
        <button onclick="document.getElementById('qr-modal').classList.add('hidden')" class="text-slate-400 hover:text-white transition-colors text-xl leading-none">&times;</button>
      </div>
      <div id="qr-canvas" class="flex justify-center mb-4"></div>
      <p id="qr-url" class="text-xs text-slate-500 break-all"></p>
    </div>
  </div>

  <script>
    // Global toast function
    function showToast(msg, type = 'info', duration = 3000) {
      const colors = { success: 'bg-emerald-600', error: 'bg-red-600', info: 'bg-violet-600', warning: 'bg-amber-600' };
      const icons = { success: '✓', error: '✕', info: 'ℹ', warning: '⚠' };
      const el = document.createElement('div');
      el.className = `pointer-events-auto flex items-center gap-3 px-4 py-3 rounded-xl text-white text-sm font-medium shadow-2xl ${colors[type]} animate-slide-up`;
      el.innerHTML = `<span class="text-base">${icons[type]}</span><span>${msg}</span>`;
      const c = document.getElementById('toast-container');
      c.appendChild(el);
      setTimeout(() => { el.style.opacity = '0'; el.style.transform = 'translateX(100%)'; el.style.transition = 'all 0.3s'; setTimeout(() => el.remove(), 300); }, duration);
    }

    // Global QR function
    function showQR(url) {
      const modal = document.getElementById('qr-modal');
      const canvas = document.getElementById('qr-canvas');
      const label = document.getElementById('qr-url');
      canvas.innerHTML = '';
      label.textContent = url;
      new QRCode(canvas, { text: url, width: 200, height: 200, colorDark: '#7c3aed', colorLight: '#0a0c12', correctLevel: QRCode.CorrectLevel.M });
      modal.classList.remove('hidden');
    }

    // Dark/Light theme toggle
    function toggleTheme() {
      const html = document.documentElement;
      html.classList.toggle('dark');
      html.classList.toggle('light');
      localStorage.setItem('droproom-theme', html.classList.contains('dark') ? 'dark' : 'light');
      document.getElementById('theme-icon')?.classList.toggle('hidden');
      document.getElementById('theme-icon-2')?.classList.toggle('hidden');
      if (document.body) {
        document.body.classList.toggle('dark');
        document.body.classList.toggle('light');
      }
    }
    // Apply saved theme on load (head)
    (function() {
      const saved = localStorage.getItem('droproom-theme');
      if (saved === 'light') {
        document.documentElement.classList.remove('dark');
        document.documentElement.classList.add('light');
      } else {
        document.documentElement.classList.add('dark');
        document.documentElement.classList.remove('light');
      }
    })();

  </script>
</body>
</html>
