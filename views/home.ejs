<div class="min-h-screen bg-[#0a0c12] bg-grid flex flex-col items-center justify-center px-4 py-16 relative overflow-hidden">
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-violet-600/5 rounded-full blur-3xl" style="pointer-events:none"></div>
  <div class="absolute bottom-0 left-1/4 w-80 h-80 bg-indigo-600/5 rounded-full blur-3xl" style="pointer-events:none"></div>

  <div class="relative z-10 w-full max-w-sm">
    <!-- Logo -->
    <div class="text-center mb-10">
      <a href="/" class="inline-flex items-center gap-3 mb-5 group">
        <img src="/logo-icon.png" alt="DropRoom" class="w-11 h-11 rounded-xl shadow-lg shadow-violet-500/30 group-hover:scale-105 transition-transform" />
        <span class="text-2xl font-bold text-white tracking-tight">DropRoom</span>
      </a>
      <p class="text-slate-400 text-sm leading-relaxed">Enter a room code to join or create a room.<br/>No login. No uploads. Just a code.</p>
    </div>

    <!-- Auth Actions -->
    <div class="mb-6 flex justify-center gap-4">
      <% if (!user) { %>
        <div class="w-full bg-surface border border-border rounded-2xl p-6 text-center shadow-2xl">
          <h2 class="text-white font-bold text-lg mb-2">Welcome to DropRoom</h2>
          <p class="text-slate-400 text-sm mb-6">Login or create an account to join and create rooms securely.</p>
          <div class="flex gap-3 justify-center mb-4">
            <button onclick="document.getElementById('login-modal').style.display='flex'" class="flex-1 max-w-[150px] py-2.5 rounded-xl border border-border text-slate-300 hover:text-white hover:border-violet-500/50 transition-colors text-sm font-semibold">Login / Signup</button>
            <a href="/auth/google" class="flex-1 max-w-[150px] py-2.5 rounded-xl bg-white text-black hover:bg-slate-200 transition-colors text-sm font-bold flex items-center justify-center gap-2 shadow-lg">
              <svg class="w-4 h-4" viewBox="0 0 24 24"><path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
              Google
            </a>
          </div>
        </div>
      <% } else { %>
        <div class="flex flex-col items-center gap-2 w-full">
          <div class="flex gap-4 w-full justify-center mb-2">
            <span class="text-emerald-400 font-semibold text-sm">Welcome, <%= user.name || user.username || user.email %>!</span>
            <a href="/profile" class="text-xs text-violet-400 hover:text-white transition-colors">Profile</a>
            <a href="/my-rooms" class="text-xs text-blue-400 hover:text-white transition-colors">My Created Rooms</a>
          </div>
        </div>
      <% } %>
    </div>
    
    <% if (user) { %>
      <!-- Single input card -->
      <div class="bg-surface border border-border rounded-2xl p-6 shadow-2xl glow-violet mb-6">
        <label class="block text-xs font-semibold text-slate-400 uppercase tracking-widest mb-3">Room Code</label>
        <input id="room-code-input" type="text" maxlength="6" placeholder="X4K9QZ"
          class="w-full bg-[#0a0c12] border border-border rounded-xl px-4 py-4 text-white text-2xl font-mono font-bold tracking-widest placeholder-slate-700 focus:border-violet-500 transition-colors text-center uppercase mb-4"
          oninput="this.value=this.value.toUpperCase().replace(/[^A-Z0-9]/g,'')"
          onkeydown="if(event.key==='Enter') goToRoom()"
          autocomplete="off" spellcheck="false" autofocus />

        <button onclick="goToRoom()" id="go-btn"
          class="w-full py-3 rounded-xl btn-primary text-sm font-semibold mb-4 flex items-center justify-center gap-2">
          <span id="go-btn-text">Enter Room →</span>
          <span id="go-spinner" style="display:none">
            <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>
          </span>
        </button>

        <div class="text-center">
          <button onclick="createFresh()" class="text-xs text-slate-600 hover:text-violet-400 transition-colors underline-offset-2 hover:underline">
            or create a new room with a random code →
          </button>
        </div>
      </div>
      
      <% if (enrichedRooms && enrichedRooms.length > 0) { %>
        <div class="mb-6 w-full text-left">
          <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">Recent Joined Rooms</h3>
          <div class="flex flex-col gap-2">
            <% enrichedRooms.slice(0, 10).forEach(r => { %>
              <div class="flex justify-between items-center bg-surface border <%= r.pinned ? 'border-violet-500/50' : 'border-border' %> rounded-xl px-4 py-3 hover:border-violet-500/50 transition-colors">
                <a href="/rooms/<%= r.roomCode %>" class="flex-1 flex flex-col">
                  <span class="font-mono font-bold text-violet-400 text-sm"><%= r.roomCode %></span>
                  <span class="text-xs text-slate-500">Created by: <%= r.creatorName %></span>
                </a>
                <button onclick="togglePin('<%= r.roomCode %>')" class="text-xl leading-none <%= r.pinned ? 'text-amber-400' : 'text-slate-500 hover:text-amber-400' %> transition-colors" title="<%= r.pinned ? 'Unpin' : 'Pin' %>">★</button>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>
    <% } %>

    <% if (error) { %>
    <div class="mb-4 flex items-center gap-3 bg-red-900/30 border border-red-500/30 text-red-400 rounded-xl px-4 py-3 text-sm">
      <span>⚠</span><span><%= error %></span>
    </div>
    <% } %>

    <!-- Features -->
    <div class="flex justify-center gap-5 mt-8 text-xs text-slate-600">
      <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-violet-500"></span>Real-time sync</span>
      <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>Links & previews</span>
      <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>Code highlighting</span>
    </div>
  </div>
</div>

<!-- ─── Create Room Dialog ─────────────────────────────────────────────────── -->
<div id="create-dialog" style="display:none;position:fixed;inset:0;z-index:50;align-items:center;justify-content:center;background:rgba(0,0,0,0.75);backdrop-filter:blur(6px)">
  <div class="bg-surface border border-border rounded-2xl p-6 w-full max-w-sm mx-4 shadow-2xl" style="animation: slideUp 0.3s cubic-bezier(0.16,1,0.3,1)">
    <!-- Header -->
    <div class="flex items-center gap-3 mb-1">
      <div class="w-9 h-9 bg-violet-500/15 border border-violet-500/20 rounded-xl flex items-center justify-center text-lg">✦</div>
      <div>
        <h2 class="text-white font-bold text-base">Create Room</h2>
        <p class="text-slate-500 text-xs">Room <span id="dialog-code" class="font-mono text-violet-400 font-bold"></span> doesn't exist yet</p>
      </div>
    </div>

    <div class="h-px bg-border my-4"></div>

    <form id="create-form" action="/rooms" method="POST">
      <input type="hidden" name="code" id="form-code" />

      <!-- TTL -->
      <label class="block text-xs font-semibold text-slate-400 uppercase tracking-widest mb-2">Expires after</label>
      <div class="grid grid-cols-5 gap-1.5 mb-4">
        <% [['1h','1h'],['6h','6h'],['24h','24h'],['7d','7d'],['never','∞']].forEach(([v,l], i) => { %>
        <label class="cursor-pointer">
          <input type="radio" name="ttl" value="<%= v %>" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)" <%= i===2?'checked':'' %> onchange="updateTTLPills(this.value)" />
          <span class="ttl-pill block text-center py-2 rounded-lg text-xs font-bold border transition-all cursor-pointer <%= i===2 ? 'pill-active border-violet-500' : 'pill-inactive border-border' %>"><%= l %></span>
        </label>
        <% }) %>
      </div>

      <!-- Password -->
      <label class="block text-xs font-semibold text-slate-400 uppercase tracking-widest mb-2">Password <span class="text-slate-600 normal-case font-normal">(optional)</span></label>
      <input name="password" type="password" placeholder="Leave blank for public room"
        class="w-full bg-[#0a0c12] border border-border rounded-xl px-4 py-2.5 text-white placeholder-slate-700 focus:border-violet-500 transition-colors text-sm mb-5" />

      <div class="flex gap-3">
        <button type="button" onclick="closeDialog()" class="flex-1 py-2.5 rounded-xl border border-border text-slate-400 hover:text-white text-sm transition-all hover:border-slate-600">
          Cancel
        </button>
        <button type="submit" class="flex-1 py-2.5 rounded-xl btn-primary text-sm font-semibold">
          Create Room →
        </button>
      </div>
    </form>
  </div>
</div>

<!-- ─── Login/Signup Dialog ─────────────────────────────────────────────────── -->
<div id="login-modal" style="display:none;position:fixed;inset:0;z-index:50;align-items:center;justify-content:center;background:rgba(0,0,0,0.75);backdrop-filter:blur(6px)">
  <div class="bg-surface border border-border rounded-2xl p-6 w-full max-w-sm mx-4 shadow-2xl" style="animation: slideUp 0.3s cubic-bezier(0.16,1,0.3,1)">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-white font-bold text-lg">Login / Signup</h2>
      <button onclick="document.getElementById('login-modal').style.display='none'" class="text-slate-400 hover:text-white">&times;</button>
    </div>
    
    <div class="mb-4">
      <label class="block text-xs font-semibold text-slate-400 uppercase tracking-widest mb-2">Email</label>
      <input id="auth-email" type="email" class="w-full bg-[#0a0c12] border border-border rounded-xl px-4 py-2 text-white placeholder-slate-700 focus:border-violet-500 transition-colors text-sm mb-3" />
      <label class="block text-xs font-semibold text-slate-400 uppercase tracking-widest mb-2">Password</label>
      <input id="auth-password" type="password" class="w-full bg-[#0a0c12] border border-border rounded-xl px-4 py-2 text-white placeholder-slate-700 focus:border-violet-500 transition-colors text-sm mb-5" />
    </div>

    <div class="flex gap-3">
      <button onclick="doAuth('/auth/login')" class="flex-1 py-2.5 rounded-xl border border-border text-slate-300 hover:text-white hover:border-violet-500/50 text-sm transition-all font-semibold">
        Login
      </button>
      <button onclick="doAuth('/auth/register')" class="flex-1 py-2.5 rounded-xl btn-primary text-sm font-semibold">
        Signup
      </button>
    </div>
  </div>
</div>

<script>
  async function doAuth(endpoint) {
    const email = document.getElementById('auth-email').value.trim();
    const password = document.getElementById('auth-password').value;
    if (!email || !password) return showToast('Email and password required', 'warning');

    try {
      const res = await fetch(endpoint, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, password })
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || data.message || 'Error occurred');
      
      location.reload();
    } catch (err) {
      showToast(err.message, 'error');
    }
  }

  function goToRoom() {
    const code = document.getElementById('room-code-input').value.trim();
    if (code.length !== 6) { showToast('Enter a 6-character room code', 'warning'); return; }

    // Show spinner
    document.getElementById('go-btn-text').textContent = 'Checking…';
    document.getElementById('go-spinner').style.display = '';
    document.getElementById('go-btn').disabled = true;

    fetch('/api/rooms/' + code)
      .then(r => {
        if (r.ok) {
          // Room exists — go straight in
          window.location.href = '/rooms/' + code;
        } else if (r.status === 404) {
          // Room doesn't exist — show create dialog
          resetBtn();
          showCreateDialog(code);
        } else {
          resetBtn();
          showToast('Something went wrong, try again', 'error');
        }
      })
      .catch(() => { resetBtn(); showToast('Cannot reach server', 'error'); });
  }

  function resetBtn() {
    document.getElementById('go-btn-text').textContent = 'Enter Room →';
    document.getElementById('go-spinner').style.display = 'none';
    document.getElementById('go-btn').disabled = false;
  }

  function createFresh() {
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
    let code = '';
    for (let i = 0; i < 6; i++) code += chars[Math.floor(Math.random() * chars.length)];
    document.getElementById('room-code-input').value = code;
    showCreateDialog(code);
  }

  function showCreateDialog(code) {
    document.getElementById('dialog-code').textContent = code;
    document.getElementById('form-code').value = code;
    const d = document.getElementById('create-dialog');
    d.style.display = 'flex';
    // reset TTL pills to 24h default
    document.querySelectorAll('input[name="ttl"]').forEach(r => { r.checked = r.value === '24h'; });
    updateTTLPills('24h');
  }

  function closeDialog() {
    document.getElementById('create-dialog').style.display = 'none';
  }

  function updateTTLPills(val) {
    document.querySelectorAll('.ttl-pill').forEach(pill => {
      const inp = pill.previousElementSibling;
      const active = inp && inp.value === val;
      // reset classes
      pill.classList.remove('pill-active', 'pill-inactive', 'border-violet-500', 'border-border');
      if (active) {
        pill.classList.add('pill-active', 'border-violet-500');
      } else {
        pill.classList.add('pill-inactive', 'border-border');
      }
    });
  }

  async function togglePin(code) {
    try {
      const res = await fetch(`/rooms/pin/${code}`, { method: 'POST' });
      const data = await res.json();
      if(data.success) {
        location.reload();
      } else {
        showToast(data.error || 'Failed to pin', 'error');
      }
    } catch(err) {
      showToast('Error connecting', 'error');
    }
  }

  // Close dialog on backdrop click
  document.getElementById('create-dialog').addEventListener('click', function(e) {
    if (e.target === this) closeDialog();
  });

  // Close on Escape
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeDialog(); });
</script>
