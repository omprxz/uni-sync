      <a href="https://github.com/omprxz" target="_blank" class="hover:text-violet-400 transition-colors flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
        omprxz
      </a>
    </div>
  </footer>

  <!-- Blobs -->
  <div class="absolute top-1/4 left-1/4 -translate-x-1/2 w-[600px] h-[600px] bg-violet-600/15 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-emerald-600/10 rounded-full blur-[120px] pointer-events-none"></div>
</div>

<% } else { %>
<!-- Dashboard Mode for Logged-in Users -->
<div class="p-6 md:p-12 max-w-4xl mx-auto flex flex-col gap-8 h-full">

  <div class="mb-2">
    <h2 class="text-3xl font-bold text-white tracking-tight mb-2">Welcome back, <%= user.name || user.username || user.email.split('@')[0] %> 👋</h2>
    <p class="text-slate-400">Join a room or create a new one to start syncing.</p>
  </div>

  <!-- Single input card -->
  <div class="bg-surface border border-border rounded-3xl p-6 md:p-10 shadow-2xl relative overflow-hidden">
    <!-- Decorative background glow -->
    <div class="absolute -top-40 -right-40 w-80 h-80 bg-violet-600/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="relative z-10 mx-auto max-w-md">
      <label class="block text-sm font-bold text-slate-400 uppercase tracking-widest mb-4 text-center">Room Code</label>
      <input id="room-code-input" type="text" maxlength="6" placeholder="X4K9QZ"
        class="w-full bg-[#0a0c12] border border-border rounded-2xl px-6 py-6 text-white text-4xl font-mono font-bold tracking-[0.3em] placeholder-slate-700/50 focus:border-violet-500 transition-colors text-center uppercase shadow-inner mb-6"
        oninput="this.value=this.value.toUpperCase().replace(/[^A-Z0-9]/g,'')"
        onkeydown="if(event.key==='Enter') goToRoom()"
        autocomplete="off" spellcheck="false" autofocus />

      <button onclick="goToRoom()" id="go-btn"
        class="w-full py-4 rounded-xl btn-primary text-base font-bold mb-6 flex items-center justify-center gap-2 shadow-lg shadow-violet-500/20">
        <span id="go-btn-text">Join Room →</span>
        <span id="go-spinner" style="display:none">
          <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>
        </span>
      </button>

      <div class="text-center">
        <button onclick="createFresh()" class="text-sm text-slate-400 hover:text-violet-400 transition-colors underline underline-offset-4 decoration-border hover:decoration-violet-500/50">
          or generate a random code and create a new room →
        </button>
      </div>
    </div>
  </div>
  
  <% if (enrichedRooms && enrichedRooms.length > 0) { %>
    <div class="mt-4">
      <div class="flex items-center justify-between mb-6 px-2">
        <h3 class="text-sm font-bold text-slate-400 uppercase tracking-widest flex items-center gap-2">
          <svg class="w-4 h-4 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Recent Joined Rooms
        </h3>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% enrichedRooms.slice(0, 10).forEach(r => { %>
          <div class="flex justify-between items-center bg-surface border <%= r.pinned ? 'border-violet-500/50 shadow-lg shadow-violet-500/10' : 'border-border' %> rounded-2xl p-4 hover:border-violet-500/50 transition-all group">
            <a href="/rooms/<%= r.roomCode %>" class="flex-1 flex items-center gap-4 min-w-0">
              <div class="w-12 h-12 rounded-xl bg-[#0a0c12] border border-border flex items-center justify-center shrink-0 <%= r.pinned ? 'text-violet-400 border-violet-500/30' : 'text-slate-400' %>">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
              </div>
              <div class="flex flex-col min-w-0">
                <span class="font-mono font-bold text-white text-lg truncate"><%= r.roomCode %></span>
                <span class="text-xs text-slate-500 truncate mt-0.5">by <%= r.creatorName %></span>
              </div>
            </a>
            <button onclick="togglePin('<%= r.roomCode %>')" class="text-xl leading-none p-2 rounded-lg <%= r.pinned ? 'text-amber-400' : 'text-slate-500 hover:text-amber-400 hover:bg-white/5 opacity-100 md:opacity-0 group-hover:opacity-100' %> transition-all" title="<%= r.pinned ? 'Unpin' : 'Pin' %>">★</button>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>
</div>
<% } %>

<% if (error) { %>
<script>
  window.addEventListener('load', () => showToast(`<%= error %>`, 'error'));
</script>
<% } %>

<!-- ─── Create Room Dialog ─────────────────────────────────────────────────── -->
<div id="create-dialog" style="display:none;position:fixed;inset:0;z-index:90;align-items:center;justify-content:center;background:rgba(0,0,0,0.75);backdrop-filter:blur(6px)">
  <div class="bg-surface border border-border rounded-3xl p-8 w-full max-w-sm mx-4 shadow-2xl relative overflow-hidden" style="animation: slideUp 0.35s cubic-bezier(0.16,1,0.3,1)">
    <!-- Decorative background glow -->
    <div class="absolute -top-40 -left-40 w-80 h-80 bg-violet-600/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="relative z-10">
      <!-- Header -->
      <div class="flex items-center gap-4 mb-2">
        <div class="w-12 h-12 bg-violet-500/10 border border-violet-500/20 rounded-xl flex items-center justify-center text-xl text-violet-400 shadow-inner">✦</div>
        <div>
          <h2 class="text-white font-bold text-lg">Create new room</h2>
          <p class="text-slate-500 text-sm">Code <span id="dialog-code" class="font-mono text-violet-400 font-bold"></span></p>
        </div>
      </div>

      <div class="h-px bg-border my-6"></div>

      <form id="create-form" action="/rooms" method="POST">
        <input type="hidden" name="code" id="form-code" />

        <!-- TTL -->
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">Room Lifespan</label>
        <div class="grid grid-cols-5 gap-2 mb-6">
          <% [['1h','1h'],['6h','6h'],['24h','24h'],['7d','7d'],['never','∞']].forEach(([v,l], i) => { %>
          <label class="cursor-pointer">
            <input type="radio" name="ttl" value="<%= v %>" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)" <%= i===2?'checked':'' %> onchange="updateTTLPills(this.value)" />
            <span class="ttl-pill block text-center py-2.5 rounded-xl text-sm font-bold border transition-all cursor-pointer <%= i===2 ? 'pill-active border-violet-500 shadow-md shadow-violet-500/20' : 'pill-inactive border-border hover:border-slate-600' %>"><%= l %></span>
          </label>
          <% }) %>
        </div>

        <!-- Password -->
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">Password <span class="text-slate-600 normal-case font-normal">(optional)</span></label>
        <input name="password" type="password" placeholder="Leave blank for public room"
          class="w-full bg-[#0a0c12]/50 border border-border rounded-xl px-4 py-3.5 text-white placeholder-slate-700 focus:border-violet-500 transition-colors text-sm shadow-inner mb-6" />

        <div class="flex gap-3 pt-2">
          <button type="button" onclick="closeDialog()" class="flex-1 py-3 rounded-xl border border-border text-slate-400 hover:text-white hover:bg-white/5 text-sm font-semibold transition-all">
            Cancel
          </button>
          <button type="submit" class="flex-1 py-3 rounded-xl btn-primary text-sm font-semibold shadow-lg shadow-violet-500/20">
            Create Room →
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ─── Login/Signup Dialog ─────────────────────────────────────────────────── -->
<div id="login-modal" style="display:none;position:fixed;inset:0;z-index:90;align-items:center;justify-content:center;background:rgba(0,0,0,0.75);backdrop-filter:blur(6px)">
  <div class="bg-surface border border-border rounded-3xl p-8 w-full max-w-sm mx-4 shadow-2xl relative overflow-hidden" style="animation: slideUp 0.35s cubic-bezier(0.16,1,0.3,1)">
    <!-- Decorative glow -->
    <div class="absolute -top-40 -left-40 w-80 h-80 bg-violet-600/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="relative z-10">
      <div class="flex justify-between items-center mb-6">
        <h2 class="text-white font-bold text-2xl tracking-tight">Access DropRoom</h2>
        <button onclick="document.getElementById('login-modal').style.display='none'" class="text-slate-500 hover:text-white transition-colors bg-white/5 hover:bg-white/10 p-2 rounded-full leading-none">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      
      <div class="mb-6">
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Email Address</label>
        <input id="auth-email" type="email" placeholder="you@example.com" class="w-full bg-[#0a0c12]/50 border border-border rounded-xl px-4 py-3 text-white placeholder-slate-700/50 focus:border-violet-500 transition-colors text-sm mb-4 shadow-inner" />
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Password</label>
        <input id="auth-password" type="password" placeholder="••••••••" class="w-full bg-[#0a0c12]/50 border border-border rounded-xl px-4 py-3 text-white placeholder-slate-700/50 focus:border-violet-500 transition-colors text-sm mb-2 shadow-inner" />
      </div>

      <div class="flex flex-col gap-3 mb-6">
        <button onclick="doAuth('/auth/login')" class="w-full py-3.5 rounded-xl btn-primary text-sm font-bold shadow-lg shadow-violet-500/20 tracking-wide">
          Log In
        </button>
        <button onclick="doAuth('/auth/register')" class="w-full py-3.5 rounded-xl border border-border text-slate-300 hover:text-white hover:bg-white/5 text-sm transition-all font-semibold">
          Create new account
        </button>
      </div>

      <div class="relative flex items-center justify-center mb-6">
        <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-border"></div></div>
        <div class="relative bg-surface px-4 text-xs text-slate-500 uppercase tracking-wider font-semibold">Or continue with</div>
      </div>
      
      <a href="/auth/google" class="w-full py-3 rounded-xl bg-white text-black hover:bg-slate-200 transition-colors text-sm font-bold flex items-center justify-center gap-3 shadow-md">
        <svg class="w-4 h-4" viewBox="0 0 24 24"><path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        Google
      </a>
    </div>
  </div>
</div>

<script>
  async function doAuth(endpoint) {
    const email = document.getElementById('auth-email').value.trim();
    const password = document.getElementById('auth-password').value;
    if (!email || !password) return showToast('Email and password required', 'warning');

    try {
      const res = await fetch(endpoint, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, password })
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || data.message || 'Error occurred');
      
      location.reload();
    } catch (err) {
      showToast(err.message, 'error');
    }
  }

  function goToRoom() {
    const code = document.getElementById('room-code-input').value.trim();
    if (code.length !== 6) { showToast('Enter a 6-character room code', 'warning'); return; }

    // Show spinner
    document.getElementById('go-btn-text').textContent = 'Checking…';
    document.getElementById('go-spinner').style.display = '';
    document.getElementById('go-btn').disabled = true;

    fetch('/api/rooms/' + code)
      .then(r => {
        if (r.ok) {
          // Room exists — go straight in
          window.location.href = '/rooms/' + code;
        } else if (r.status === 404) {
          // Room doesn't exist — show create dialog
          resetBtn();
          showCreateDialog(code);
        } else {
          resetBtn();
          showToast('Something went wrong, try again', 'error');
        }
      })
      .catch(() => { resetBtn(); showToast('Cannot reach server', 'error'); });
  }

  function resetBtn() {
    document.getElementById('go-btn-text').textContent = 'Join Room →';
    document.getElementById('go-spinner').style.display = 'none';
    document.getElementById('go-btn').disabled = false;
  }

  function createFresh() {
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
    let code = '';
    for (let i = 0; i < 6; i++) code += chars[Math.floor(Math.random() * chars.length)];
    const codeInput = document.getElementById('room-code-input');
    if (codeInput) codeInput.value = code;
    showCreateDialog(code);
  }

  function showCreateDialog(code) {
    document.getElementById('dialog-code').textContent = code;
    document.getElementById('form-code').value = code;
    const d = document.getElementById('create-dialog');
    d.style.display = 'flex';
    // reset TTL pills to 24h default
    document.querySelectorAll('input[name="ttl"]').forEach(r => { r.checked = r.value === '24h'; });
    updateTTLPills('24h');
  }

  function closeDialog() {
    document.getElementById('create-dialog').style.display = 'none';
  }

  function updateTTLPills(val) {
    document.querySelectorAll('.ttl-pill').forEach(pill => {
      const inp = pill.previousElementSibling;
      const active = inp && inp.value === val;
      // reset classes
      pill.classList.remove('pill-active', 'pill-inactive', 'border-violet-500', 'border-border', 'shadow-md', 'shadow-violet-500/20');
      if (active) {
        pill.classList.add('pill-active', 'border-violet-500', 'shadow-md', 'shadow-violet-500/20');
      } else {
        pill.classList.add('pill-inactive', 'border-border');
      }
    });
  }

  async function togglePin(code) {
    try {
      const res = await fetch(`/rooms/pin/${code}`, { method: 'POST' });
      const data = await res.json();
      if(data.success) {
        location.reload();
      } else {
        showToast(data.error || 'Failed to pin', 'error');
      }
    } catch(err) {
      showToast('Error connecting', 'error');
    }
  }

  // Close dialog on backdrop click
  document.getElementById('create-dialog').addEventListener('click', function(e) {
    if (e.target === this) closeDialog();
  });
  
  document.getElementById('login-modal').addEventListener('click', function(e) {
    if (e.target === this) this.style.display = 'none';
  });

  // Close on Escape
  document.addEventListener('keydown', e => { 
    if (e.key === 'Escape') {
      closeDialog(); 
      document.getElementById('login-modal').style.display = 'none';
    }
  });
</script>
