<div class="min-h-screen bg-[#0a0c12] bg-grid flex flex-col items-center justify-center px-4 relative overflow-hidden">
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-96 h-96 bg-violet-600/5 rounded-full blur-3xl pointer-events-none"></div>
  <div class="relative z-10 w-full max-w-sm text-center">
    <a href="/" class="inline-flex items-center gap-2 mb-8 opacity-80 hover:opacity-100 transition-opacity">
      <div class="w-8 h-8 bg-gradient-to-br from-violet-500 to-indigo-600 rounded-lg flex items-center justify-center">
        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      </div>
      <span class="font-bold text-white">DropRoom</span>
    </a>

    <div class="bg-surface border border-border rounded-2xl p-8 shadow-2xl glow-violet">
      <div class="w-14 h-14 bg-amber-500/10 border border-amber-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
        <span class="text-2xl">🔒</span>
      </div>
      <h1 class="text-xl font-bold text-white mb-1">Password Required</h1>
      <p class="text-slate-400 text-sm mb-6">Room <span class="font-mono font-bold text-violet-400"><%= code %></span> is password-protected.</p>

      <% if (error) { %>
      <div class="mb-4 bg-red-900/30 border border-red-500/30 text-red-400 rounded-xl px-4 py-3 text-sm text-left">
        Wrong password. Try again.
      </div>
      <% } %>

      <form action="/rooms/<%= code %>/verify" method="POST">
        <input type="password" name="password" placeholder="Enter room password" autofocus
          class="w-full bg-[#0a0c12] border border-border rounded-xl px-4 py-3 text-white placeholder-slate-700 focus:border-violet-500 transition-colors text-sm mb-4" />
        <button type="submit" class="w-full py-3 rounded-xl btn-primary text-sm font-semibold">
          Enter Room →
        </button>
      </form>
    </div>
  </div>
</div>
