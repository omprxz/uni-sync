<!-- Room data injected for client JS -->
<script>
  window.ROOM_CODE = '<%- roomCode %>';
  window.ROOM_DATA = <%- roomData %>;
  window.INITIAL_ITEMS = <%- initialItems %>;
</script>

<!-- NAVBAR -->
<header class="sticky top-0 z-40 border-b border-border bg-[#0a0c12]/90 backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-4 flex items-center gap-3 h-14">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 shrink-0 group">
      <img src="/logo-icon.png" alt="DropRoom" class="w-7 h-7 rounded-lg group-hover:scale-105 transition-transform" />
      <span class="text-sm font-bold text-white hidden sm:block">DropRoom</span>
    </a>

    <div class="w-px h-5 bg-border mx-1 hidden sm:block"></div>

    <!-- Room code chip -->
    <button id="room-code-chip" onclick="copyRoomCode()" class="flex items-center gap-2 bg-surface border border-border rounded-xl px-3 py-1.5 text-xs font-mono font-bold text-violet-400 hover:border-violet-500/60 transition-all group">
      <span><%- roomCode %></span>
      <svg class="w-3.5 h-3.5 text-slate-600 group-hover:text-violet-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
    </button>

    <!-- TTL countdown -->
    <div id="ttl-display" class="hidden items-center gap-1.5 text-xs text-slate-500 bg-surface border border-border rounded-xl px-3 py-1.5">
      <svg class="w-3.5 h-3.5 text-amber-400 animate-pulse-soft" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <span id="ttl-timer" class="font-mono text-amber-400 font-semibold"></span>
    </div>

    <div class="flex-1"></div>

    <!-- User count -->
    <div class="flex items-center gap-1.5 text-xs text-slate-400 bg-surface border border-border rounded-xl px-3 py-1.5">
      <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse-soft"></span>
      <span id="user-count">1</span>
      <span class="hidden sm:inline text-slate-600">online</span>
    </div>

    <!-- Item count -->
    <div class="hidden sm:flex items-center gap-1.5 text-xs text-slate-400 bg-surface border border-border rounded-xl px-3 py-1.5">
      <span id="item-count">0</span>
      <span class="text-slate-600">items</span>
    </div>



    <!-- Logout -->
    <button onclick="logout()" class="p-2 rounded-xl bg-surface border border-border text-slate-400 hover:text-red-400 hover:border-red-500/50 transition-all" title="Leave Room">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
    </button>

    <!-- Theme toggle -->
    <button onclick="toggleTheme()" class="p-2 rounded-xl bg-surface border border-border text-slate-400 hover:text-white hover:border-violet-500/50 transition-all">
      <svg id="theme-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
      <svg id="theme-icon-2" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707"/></svg>
    </button>
  </div>

  <!-- Activity feed -->
  <div id="activity-bar" class="border-t border-border/50 bg-[#0a0c12]/50 overflow-hidden transition-all duration-300" style="max-height:0">
    <div class="max-w-7xl mx-auto px-4 py-2 flex flex-col gap-1" id="activity-list"></div>
  </div>
  <button onclick="toggleActivity()" id="activity-toggle-btn" class="w-full flex items-center justify-center gap-2 py-1 text-xs text-slate-600 hover:text-slate-400 transition-colors border-t border-border/30">
    <span id="activity-toggle-label">▼ Show activity</span>
  </button>
</header>

<!-- Typing indicator -->
<div id="typing-indicator" class="hidden max-w-7xl mx-auto px-4 pt-2 text-xs text-slate-500 italic animate-pulse-soft">
  Someone is typing...
</div>

<!-- MAIN CONTENT -->
<main class="max-w-7xl mx-auto px-4 py-6">

  <!-- INPUT AREA -->
  <div id="input-area" class="bg-surface border border-border rounded-2xl p-4 mb-6 glow-violet-sm transition-all">
    <div class="flex items-start gap-3">
      <div class="flex-1">
        <!-- Type badge (auto-detected) -->
        <div class="flex items-center gap-2 mb-2">
          <span id="detected-type-badge" class="text-xs font-bold px-2.5 py-1 rounded-full border bg-violet-500/15 text-violet-400 border-violet-500/20 transition-all">✦ Text</span>
          <span class="text-xs text-slate-600">Auto-detected type</span>
          <span id="char-count" class="ml-auto text-xs text-slate-600">0 / 10,000</span>
        </div>
        <textarea id="new-content" rows="3" placeholder="Paste or type anything — links, code, notes, markdown... (or press Ctrl+V anywhere)"
          class="w-full bg-[#0a0c12] border border-border rounded-xl px-4 py-3 text-white text-sm placeholder-slate-700 focus:border-violet-500 transition-colors resize-none font-sans"
          oninput="onContentInput(this.value)" onkeydown="onContentKeydown(event)"></textarea>
        <div class="flex gap-3 mt-2.5">
          <input id="new-label" type="text" maxlength="200" placeholder="Label / title (optional)"
            class="flex-1 bg-[#0a0c12] border border-border rounded-xl px-4 py-2.5 text-white text-sm placeholder-slate-700 focus:border-violet-500 transition-colors" />
          <label class="cursor-pointer px-4 py-2.5 rounded-xl border border-border bg-surface text-slate-400 hover:text-white hover:border-violet-500/50 transition-all flex items-center justify-center gap-2 tooltip" title="Upload Image or File">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>
            <input type="file" class="hidden" onchange="handleFileInput(event)" />
          </label>
          <button onclick="submitItem()" id="submit-btn"
            class="px-5 py-2.5 rounded-xl btn-primary text-sm font-semibold whitespace-nowrap disabled:opacity-40 disabled:cursor-not-allowed disabled:transform-none disabled:shadow-none">
            + Add
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- FILTER + SEARCH + SORT BAR -->
  <div class="flex flex-wrap gap-2 items-center mb-6">
    <!-- Type filter pills -->
    <div class="flex gap-1 bg-surface border border-border rounded-xl p-1" id="filter-pills">
      <% [['all','All'], ['text','Text'], ['link','Links'], ['code','Code'], ['markdown','MD']].forEach(([v,l]) => { %>
      <button onclick="setFilter('<%= v %>')" data-filter="<%= v %>"
        class="filter-pill px-3 py-1.5 rounded-lg text-xs font-semibold transition-all <%= v==='all' ? 'pill-active' : 'pill-inactive' %>">
        <%= l %>
      </button>
      <% }) %>
    </div>

    <!-- Search -->
    <div class="flex-1 min-w-[160px] relative">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-600 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      <input id="search-input" type="text" placeholder="Search items..." oninput="setSearch(this.value)"
        class="w-full bg-surface border border-border rounded-xl pl-9 pr-4 py-2 text-sm text-white placeholder-slate-600 focus:border-violet-500 transition-colors" />
    </div>

    <!-- Sort -->
    <div class="relative group" id="sort-dropdown">
      <button class="flex items-center gap-2 bg-surface text-slate-300 border border-border rounded-xl px-3 py-2 text-sm focus:border-violet-500 transition-colors cursor-pointer w-36 justify-between">
        <span id="sort-label">Newest first</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div class="absolute right-0 mt-2 w-36 bg-[#0a0c12] border border-border rounded-xl shadow-xl shadow-black/50 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-10 overflow-hidden">
        <button onclick="setSort('newest'); document.getElementById('sort-label').textContent='Newest first'" class="w-full text-left px-4 py-2.5 text-sm text-slate-300 hover:bg-violet-500/10 hover:text-violet-400">Newest first</button>
        <button onclick="setSort('oldest'); document.getElementById('sort-label').textContent='Oldest first'" class="w-full text-left px-4 py-2.5 text-sm text-slate-300 hover:bg-violet-500/10 hover:text-violet-400 border-t border-border">Oldest first</button>
      </div>
    </div>

    <!-- View mode toggle -->
    <div class="flex gap-1 bg-surface border border-border rounded-xl p-1">
      <button onclick="setViewMode('comfortable')" id="view-comfortable"
        class="p-1.5 rounded-lg text-slate-400 hover:text-white transition-colors pill-active" title="Comfortable view">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
      </button>
      <button onclick="setViewMode('compact')" id="view-compact"
        class="p-1.5 rounded-lg text-slate-400 hover:text-white transition-colors pill-inactive" title="Compact view">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>

  <!-- ITEMS GRID -->
  <div id="items-container" class="columns-1 md:columns-2 xl:columns-3 gap-4 space-y-4">
    <!-- Populated by room.js -->
  </div>

  <!-- Empty state -->
  <div id="empty-state" class="hidden text-center py-24">
    <div class="w-16 h-16 bg-surface border border-border rounded-2xl flex items-center justify-center mx-auto mb-4">
      <svg class="w-8 h-8 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
    </div>
    <p class="text-slate-500 font-medium mb-1">No items yet</p>
    <p class="text-slate-700 text-sm">Paste or type something above to get started</p>
  </div>

  <!-- Skeleton loader -->
  <div id="skeleton-loader" class="columns-1 md:columns-2 xl:columns-3 gap-4 space-y-4">
    <% for(let i=0; i<3; i++) { %>
    <div class="bg-surface border border-border rounded-2xl p-5 animate-pulse">
      <div class="flex gap-2 mb-4"><div class="h-5 w-16 bg-border rounded-full"></div></div>
      <div class="h-4 bg-border rounded mb-2 w-3/4"></div>
      <div class="h-4 bg-border rounded mb-2 w-full"></div>
      <div class="h-4 bg-border rounded w-2/3"></div>
    </div>
    <% } %>
  </div>
</main>

<!-- Inline edit modal -->
<div id="edit-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/70 backdrop-blur-sm px-4">
  <div class="bg-surface border border-border rounded-2xl p-6 w-full max-w-lg shadow-2xl animate-slide-up">
    <div class="flex justify-between items-center mb-4">
      <span class="font-semibold text-white">Edit Item</span>
      <button onclick="closeEditModal()" class="text-slate-400 hover:text-white transition-colors text-xl leading-none">&times;</button>
    </div>
    <input id="edit-label" type="text" maxlength="200" placeholder="Label (optional)"
      class="w-full bg-[#0a0c12] border border-border rounded-xl px-4 py-2.5 text-white text-sm placeholder-slate-700 focus:border-violet-500 transition-colors mb-3" />
    <textarea id="edit-content" rows="6"
      class="w-full bg-[#0a0c12] border border-border rounded-xl px-4 py-3 text-white text-sm focus:border-violet-500 transition-colors resize-none font-mono"></textarea>
    <div class="flex gap-3 mt-4">
      <button onclick="closeEditModal()" class="flex-1 py-2.5 rounded-xl border border-border text-slate-400 hover:text-white text-sm transition-all">Cancel</button>
      <button onclick="saveEdit()" class="flex-1 py-2.5 rounded-xl btn-primary text-sm font-semibold">Save Changes</button>
    </div>
  </div>
</div>

<!-- Socket.io client -->
<script src="/socket.io/socket.io.js"></script>
<script src="/js/room.js"></script>

<!-- Bottom Sheet -->
<div id="bottom-sheet" class="fixed inset-x-0 bottom-0 z-50 transform translate-y-full transition-transform duration-300 ease-out bg-surface border-t border-border shadow-[0_-20px_60px_-10px_rgba(0,0,0,0.5)] rounded-t-3xl max-h-[85vh] flex flex-col">
  <div class="p-4 flex items-center justify-between border-b border-border/50 sticky top-0 bg-surface/90 backdrop-blur rounded-t-3xl z-10">
    <h3 class="text-white font-medium">Item Details</h3>
    <button onclick="closeBottomSheet()" class="text-slate-400 hover:text-white transition-colors bg-white/5 p-2 rounded-full leading-none">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </div>
  <div id="bottom-sheet-content" class="p-6 overflow-y-auto max-w-4xl mx-auto w-full">
    <!-- Populated dynamically -->
  </div>
</div>
